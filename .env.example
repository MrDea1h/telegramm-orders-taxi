# --- Postgres (compose container) ---
POSTGRES_DB=corpride
POSTGRES_USER=corpride
POSTGRES_PASSWORD=corpride

# --- Core services ---
ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://corpride:corpride@localhost:5432/corpride
DB_ECHO=false
REDIS_URL=redis://localhost:6379/0

# --- Telegram bot ---
BOT_TOKEN=
BOT_MODE=polling
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=

# --- Auth (reserved for M2) ---
JWT_SECRET=dev-insecure-secret-change-me
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
INIT_DATA_MAX_AGE_SEC=3600
TELEGRAM_LOGIN_WIDGET_MAX_AGE_SEC=86400
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# --- Web Push (reserved for M4) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com

# --- Email (reserved for M2) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CorpRide <no-reply@example.com>
SMTP_USE_TLS=true
VERIFICATION_CODE_TTL_MIN=10
VERIFICATION_CODE_MAX_ATTEMPTS=5

# --- Booking policy defaults ---
ORDER_BOOKING_HORIZON_DAYS=14
ORDER_MIN_LEAD_MIN=30
ORDER_BUFFER_MIN=15

# --- Misc ---
ADMIN_TELEGRAM_IDS=
CORS_ALLOW_ORIGINS=
SENTRY_DSN=
