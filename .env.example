# --- Postgres (compose container) ---
POSTGRES_DB=apexride
POSTGRES_USER=apexride
POSTGRES_PASSWORD=apexride

# --- Core services ---
ENV=dev
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://apexride:apexride@localhost:5432/apexride
DB_ECHO=false
REDIS_URL=redis://localhost:6379/0

# --- Telegram bot ---
BOT_TOKEN=
BOT_MODE=polling
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=
WEBAPP_URL=

# --- Host ports (change per-host to avoid clashing with another stack) ---
# api is 127.0.0.1-only (never exposed directly); webapp is the one thing
# meant to be reached from a real browser, so it isn't localhost-bound.
API_HOST_PORT=8000
WEBAPP_HOST_PORT=8080

# --- Auth (Telegram is the only login method) ---
JWT_SECRET=dev-insecure-secret-change-me
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
INIT_DATA_MAX_AGE_SEC=3600
TELEGRAM_LOGIN_WIDGET_MAX_AGE_SEC=86400

# --- Web Push (reserved for M4) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com

# --- Booking policy defaults ---
ORDER_BOOKING_HORIZON_DAYS=14
ORDER_MIN_LEAD_MIN=30
ORDER_BUFFER_MIN=15

# --- Misc ---
CORS_ALLOW_ORIGINS=
SENTRY_DSN=
