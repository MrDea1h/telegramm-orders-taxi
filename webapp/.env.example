VITE_API_BASE_URL=http://localhost:8000

# Blank by default — TelegramLoginButton renders nothing until a real bot
# with a public username (and /setdomain configured via BotFather) exists.
VITE_TELEGRAM_BOT_USERNAME=

# Blank by default — the order wizard's ETA step falls back to the backend's
# haversine estimate until this is set. Once a real JavaScript API key
# exists, real routing (with traffic) kicks in automatically, no code
# changes needed — see src/lib/yandexMaps.ts.
VITE_YANDEX_MAPS_API_KEY=

# Geocoder — powers address <-> coordinates in the order wizard (see
# src/lib/yandexGeocoder.ts). Blank = wizard falls back to the manual
# map picker (src/components/MapAddressPicker.tsx) for every address.
VITE_YANDEX_GEOCODER_API_KEY=

# Reserved — not wired into any screen yet.
VITE_YANDEX_GEOSUGGEST_API_KEY=
VITE_YANDEX_STATIC_API_KEY=
